<h1>User Details</h1>

<p>
  <strong>Name:</strong>
  <%= @user.name %>
</p>

<p>
  <strong>Email:</strong>
  <%= @user.email %>
</p>

<p>
  <strong>Created:</strong>
  <%= @user.created_at.strftime("%B %d, %Y") %>
</p>

<%= link_to "Edit", edit_user_path(@user) %> |
<%= link_to "Back", users_path %> |
<%= button_to "Destroy", @user, method: :delete, data: { confirm: "Are you sure?" } %>
